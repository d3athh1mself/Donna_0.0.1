# Application
APP_NAME=Denali Craft Operations Platform
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=replace-with-a-secure-random-value

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=denali_craft_ops
POSTGRES_USER=denali_app
POSTGRES_PASSWORD=replace-with-database-password

# Local file storage
STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=25

# Frontend
FRONTEND_URL=http://localhost:5173

# OpenAI — configure during the OCR phase
OPENAI_API_KEY=
